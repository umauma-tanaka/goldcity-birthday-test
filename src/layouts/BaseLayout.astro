---
import "../styles/global.css";
import { withBase } from "@lib/paths";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pageTitle = `${title} | Gold City Birthday Archive`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6f2ea" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="page-bg"></div>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand-link" href={withBase("/")}>
          <span class="brand-mark">GC</span>
          <span class="brand-copy">
            <strong>Gold City Birthday Archive</strong>
            <small>投稿者ごとに読む、生誕祭のための静かな展示室</small>
          </span>
        </a>
      </header>

      <main class="main-shell">
        <slot />
      </main>

      <footer class="site-footer">
        <p>Astro と GitHub Pages で公開できる、完全静的な投稿アーカイブです。</p>
      </footer>
    </div>
  </body>
</html>

